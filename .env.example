# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-new-one
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# PayMongo API Keys
PAYMONGO_SECRET_KEY=sk_test_your_secret_key
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret

# Database (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@localhost:5432/labhatud_db

# Security Settings (Enable for production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
